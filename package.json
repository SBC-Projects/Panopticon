{
  "name": "panopticon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node -e \"const fs=require('fs');for (const p of ['node_modules/.vite','dist']) fs.rmSync(p,{recursive:true,force:true});\" && npm run dev",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:web": "vite --force",
    "build": "vite build",
    "start": "tsx server/src/index.ts",
    "scan": "tsx server/src/index.ts --scan",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mammoth": "^1.9.0",
    "open": "^10.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "svelte": "^5.20.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.7"
  }
}
